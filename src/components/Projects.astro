---
// Each project is an object. Adding a new project is as simple as adding a new item here.
const projects = [
  {
    number: '01',
    title: 'RFQ / RFP Generator',
    category: 'Web App',
    description:
      'A web application built for e-logic.us that streamlines the generation of quotes, Requests for Quote (RFQ), and Requests for Proposal (RFP). Currently in production and actively used.',
    tags: ['PHP', 'Web', 'Business Tools'],
    link: 'http://137.184.59.169/',
    linkLabel: 'View Live',
  },
  {
    number: '02',
    title: 'ClickUp AI Agent',
    category: 'AI Automation',
    description:
      'A SmythOS AI agent integrated with the ClickUp API that autonomously writes test cases, creates bug tickets, and drafts user stories — eliminating repetitive QA documentation work.',
    tags: ['SmythOS', 'ClickUp API', 'AI Agent', 'QA Automation'],
    link: null,
    linkLabel: null,
  },
  {
    number: '03',
    title: 'Sprint Release Notes Agent',
    category: 'AI Automation',
    description:
      'Scheduled agent that runs every Monday, pulls all tickets completed in the previous sprint from ClickUp, and automatically generates structured release notes — no manual effort required.',
    tags: ['SmythOS', 'ClickUp API', 'Scheduling', 'AI Agent'],
    link: null,
    linkLabel: null,
  },
  {
    number: '04',
    title: 'Stripe Payment Failure Agent',
    category: 'AI Automation',
    description:
      'A webhook-driven SmythOS agent connected to Stripe that detects failed payments in real time and automatically sends personalized customer notification emails.',
    tags: ['SmythOS', 'Stripe API', 'Webhooks', 'AI Agent'],
    link: null,
    linkLabel: null,
  },
  {
    number: '05',
    title: 'Test Cases RAG Agent',
    category: 'AI / Knowledge Base',
    description:
      'Indexes an entire test case repository into a Retrieval-Augmented Generation (RAG) system, allowing team members to query and retrieve relevant test cases instantly through a conversational AI agent.',
    tags: ['SmythOS', 'RAG', 'AI Agent', 'QA'],
    link: null,
    linkLabel: null,
  },
  {
    number: '06',
    title: 'SmythOS Docs RAG Agent',
    category: 'AI / Knowledge Base',
    description:
      'Indexes the full SmythOS documentation into a RAG knowledge base, enabling an AI agent to answer technical questions about the platform without manual documentation browsing.',
    tags: ['SmythOS', 'RAG', 'AI Agent', 'Documentation'],
    link: null,
    linkLabel: null,
  },
];
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <p class="font-mono text-accent text-sm mb-3" data-aos="fade-up">03. projects</p>
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-100 mb-12" data-aos="fade-up" data-aos-delay="100">Things I've Built</h2>

    <div class="space-y-6">
      {projects.map((project, i) => (
        <div
          class="group rounded-xl border border-slate-800 bg-navy-800 p-6 hover:border-accent/30 transition-colors"
          data-aos="fade-up"
          data-aos-delay={i * 80}
        >
          <div class="flex items-start justify-between gap-4 mb-3">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-slate-600">{project.number}</span>
              <span class="text-xs font-mono px-2 py-0.5 rounded-full border border-slate-700 text-slate-500">
                {project.category}
              </span>
            </div>
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-xs text-accent hover:underline font-mono flex-shrink-0"
              >
                {project.linkLabel}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>

          <h3 class="text-lg font-semibold text-slate-100 mb-2 group-hover:text-accent transition-colors">
            {project.title}
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">{project.description}</p>

          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-900 border border-slate-800 text-slate-500">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

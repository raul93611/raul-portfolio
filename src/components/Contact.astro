---

<section id="contact" class="py-24 px-6 bg-navy-800/40">
  <div class="max-w-4xl mx-auto">
    <p class="font-mono text-accent text-sm mb-3" data-aos="fade-up">04. contact</p>
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4" data-aos="fade-up" data-aos-delay="100">Let's Work Together</h2>
    <p class="text-slate-400 text-lg max-w-xl mb-12" data-aos="fade-up" data-aos-delay="150">
      Whether you need an AI agent built from scratch or a reliable QA engineer to validate your product — I'm available for freelance projects.
    </p>

    <div class="grid sm:grid-cols-2 gap-4">
      {links.map((link, i) => (
        <a
          data-aos="fade-up"
          data-aos-delay={200 + i * 80}
          href={link.href}
          target={link.href.startsWith('mailto') ? '_self' : '_blank'}
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-4 rounded-xl border border-slate-800 bg-navy-800 hover:border-accent/40 hover:text-accent text-slate-400 transition-colors group"
        >
          <span class="group-hover:text-accent transition-colors" set:html={link.icon} />
          <span class="font-medium text-slate-300 group-hover:text-accent transition-colors">
            {link.label}
          </span>
          <svg class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-8 px-6 border-t border-slate-800/50">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="font-mono text-slate-600 text-sm">Leonardo Raul Velasco</span>
    <span class="font-mono text-slate-700 text-xs">Built with Astro &amp; Tailwind CSS</span>
  </div>
</footer>
